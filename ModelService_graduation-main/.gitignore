#
# Global rule: only track code / text; ignore所有模型、图片、数据集、大文件
#

# 1. 先忽略所有文件
*

# 2. 允许目录本身被递归检查
!*/

# 3. 允许 Git 配置文件
!.gitignore
!.gitattributes

# 4. 允许常见代码和配置（文本文件）
!*.py
!*.ipynb
!*.js
!*.jsx
!*.ts
!*.tsx
!*.vue
!*.html
!*.htm
!*.css
!*.scss
!*.less
!*.json
!*.yml
!*.yaml
!*.ini
!*.cfg
!*.conf
!*.toml
!*.env
!*.txt
!*.md
!*.csv
!*.tsv
!*.xml
!*.log
!*.ps1
!*.sh
!*.bat
!*.cmd
!*.sql
!Dockerfile
!Dockerfile.*

# 5. 允许前端相关配置
!package.json
!package-lock.json
!pnpm-lock.yaml
!yarn.lock
!vite.config.*
!webpack.config.*

# 6. 显式忽略常见模型文件 / 大文件（即使上面 * 理论上已经忽略）
*.pt
*.pth
*.onnx
*.h5
*.ckpt
*.weights
*.pb
*.pkl
*.joblib
*.npz
*.npy
*.sav

# 7. 忽略图片 / 视频 / 媒体资源
*.png
*.jpg
*.jpeg
*.jpe
*.bmp
*.gif
*.webp
*.svg
*.tif
*.tiff
*.ico
*.psd
*.ai
*.mp4
*.avi
*.mov
*.mkv
*.wmv
*.flv
*.mp3
*.wav

# 8. 忽略压缩包、可执行文件等
*.zip
*.rar
*.7z
*.tar
*.gz
*.bz2
*.xz
*.iso
*.exe
*.dll
*.so
*.dylib
*.obj
*.o
*.a
*.lib

# 9. 忽略 Python / Node 运行产生的中间文件
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.coverage
dist/
build/
node_modules/

__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
.env
.venv
venv/
ENV/

node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn
.pnp.*

.idea/
.vscode/
*.swp
*.swo
*~

.DS_Store
Thumbs.db

